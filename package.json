{
  "name": "@drawo-app/drawo",
  "version": "2.0.10",
  "type": "module",
  "description": "A beautiful, customizable whiteboard component for React",
  "author": "drawo contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/drawo-app/drawo"
  },
  "keywords": [
    "whiteboard",
    "canvas",
    "drawing",
    "react",
    "react-component",
    "collaboration",
    "sketch",
    "diagram"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/drawo.css",
    "./cursors/*": "./dist/cursors/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && cp src/lib/index.d.ts dist/index.d.ts && cp src/lib/index.d.ts dist/index.d.cts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@gravity-ui/icons": "^2.17.0",
    "@solar-icons/react": "^1.1.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@uiw/react-color-chrome": "^2.9.5",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "slate": "^0.123.0",
    "slate-dom": "^0.123.0",
    "slate-history": "^0.113.1",
    "slate-react": "^0.123.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "vite": "^7.3.1"
    }
  }
}
